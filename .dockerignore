# ============================================
# IP Watch AI - Docker Ignore
# Keeps build context small (<100MB)
# ============================================

# Large data directories
bulletins/
clients/
models/
backup_20260207/
.py/
python/
cloudflared/
deploy/
tests/
docs/
scripts/
dogan_patent/
dogan_patent_processed/
ocr_output/
temp_ocr_processing/
temp_uploads/
tescil_pdfs/
qdrant-x86_64-pc-windows-msvc/
trademark-system/

# AI Model files (mounted as volumes instead)
*.pth
*.pt
*.bin
*.safetensors
*.onnx
*.h5
*.pkl
*.pickle
*.joblib

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
ENV/
env/
.conda/

# Git
.git/
.gitignore
.gitattributes

# Logs
logs/
*.log
pipeline.log
patent_extraction.log

# Database dumps
*.dump
*.backup
backups/
pgdata/
pgsql/

# Node
node_modules/
npm-debug.log

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker
.docker/
docker-compose.override.yml

# Test files
.pytest_cache/
.coverage
htmlcov/
.tox/

# Installers and executables
*.exe
*.msi
*.dll

# Large archives
*.zip
*.tar
*.tar.gz
*.7z
*.rar

# Reports (generated at runtime)
reports/
uploads/

# Environment files (secrets)
.env
.env.*
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
nul

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Cache directories
.cache/
*.cache

# Documentation (not needed in container)
*.md
!requirements.txt

# Excel/data files
*.xlsx
*.xls
*.csv

# Images (except static assets)
!static/**/*.png
!static/**/*.jpg
!static/**/*.ico
!static/**/*.svg
