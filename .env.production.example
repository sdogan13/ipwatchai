# ============================================
# IP Watch AI - Production Environment
# Copy to .env and fill in your values
# ============================================

# ==========================================
# Application Settings
# ==========================================
APP_NAME="IP Watch AI"
APP_VERSION="1.0.0"
ENVIRONMENT=production
DEBUG=false
USE_UNIFIED_SCORING=true
HOST=0.0.0.0
PORT=8000
# Keep the default backend worker count at 1 unless the search stack is
# explicitly revalidated for multi-worker stability.
WORKERS=1

# ==========================================
# Database (PostgreSQL)
# ==========================================
# Docker Compose (services communicate via internal network):
DB_HOST=postgres
DB_PORT=5432
# Local development (connecting to Docker-exposed port):
# DB_HOST=127.0.0.1
# DB_PORT=5433
DB_NAME=trademark_db
DB_USER=turk_patent
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD

# ==========================================
# Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ==========================================
# Authentication (IMPORTANT: Change these!)
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET_KEY=GENERATE_A_SECURE_64_CHAR_SECRET_KEY_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AI Settings
# ==========================================
AI_DEVICE=cuda
USE_FP16=true
USE_TF32=true
CLIP_BATCH_SIZE=64
DINO_BATCH_SIZE=32
TEXT_BATCH_SIZE=256

# ==========================================
# CORS Origins
# ==========================================
# Production:
CORS_ORIGINS=["https://ipwatchai.com","https://www.ipwatchai.com"]
# Development:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==========================================
# File Paths (on host machine)
# ==========================================
DATA_PATH=C:/Users/701693/turk_patent/bulletins
CLIENTS_PATH=C:/Users/701693/turk_patent/clients
HF_HOME=C:/Users/701693/.cache/huggingface
TORCH_HOME=C:/Users/701693/.cache/torch

# ==========================================
# Email (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=info@ipwatchai.com
FROM_NAME=IP Watch AI

# ==========================================
# Cloudflare Tunnel
# ==========================================
# Tunnel credentials are stored in ./cloudflared/
# TUNNEL_TOKEN is provided when you create the tunnel
CLOUDFLARE_TUNNEL_TOKEN=YOUR_TUNNEL_TOKEN

# ==========================================
# Monitoring (Optional)
# ==========================================
# Sentry DSN for error tracking
SENTRY_DSN=

# ==========================================
# Development Tools (Optional)
# ==========================================
PGADMIN_EMAIL=info@ipwatchai.com
PGADMIN_PASSWORD=change_this_password

# ==========================================
# Rate Limits
# ==========================================
LOGIN_RATE_LIMIT=5
API_RATE_LIMIT=100

# ==========================================
# iyzico Payment Gateway
# ==========================================
# Production: https://api.iyzipay.com
# Sandbox:    https://sandbox-api.iyzipay.com
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_API_KEY=YOUR_IYZICO_LIVE_API_KEY
IYZICO_SECRET_KEY=YOUR_IYZICO_LIVE_SECRET_KEY
IYZICO_CALLBACK_URL=https://ipwatchai.com/api/v1/payments/callback
IYZICO_WEBHOOK_URL=https://ipwatchai.com/api/v1/payments/webhook

# ==========================================
# Stripe Payment Gateway
# ==========================================
# Used for UK and Europe billing regions. Configure Stripe Tax in Stripe,
# then set webhook forwarding to /api/v1/payments/stripe/webhook.
STRIPE_SECRET_KEY=YOUR_STRIPE_LIVE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SIGNING_SECRET
STRIPE_SUCCESS_URL=https://ipwatchai.com/dashboard?payment=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://ipwatchai.com/checkout?error=payment_cancelled
STRIPE_AUTOMATIC_TAX=true

# Regional billing display prices and Stripe Price IDs.
# UK -> Stripe GBP, EU -> Stripe EUR, TR -> iyzico TRY.
BILLING_REGION_CATALOG_JSON={"UK":{"plans":{"starter":{"price_monthly":29,"price_annual_monthly":23,"stripe_price_monthly":"price_REPLACE_UK_STARTER_MONTH","stripe_price_annual":"price_REPLACE_UK_STARTER_YEAR"},"professional":{"price_monthly":99,"price_annual_monthly":79,"stripe_price_monthly":"price_REPLACE_UK_PRO_MONTH","stripe_price_annual":"price_REPLACE_UK_PRO_YEAR"},"enterprise":{"price_monthly":249,"price_annual_monthly":199,"stripe_price_monthly":"price_REPLACE_UK_ENT_MONTH","stripe_price_annual":"price_REPLACE_UK_ENT_YEAR"}},"credit_packs":{"small":{"price":5,"stripe_price":"price_REPLACE_UK_CREDITS_SMALL"},"medium":{"price":15,"stripe_price":"price_REPLACE_UK_CREDITS_MEDIUM"},"large":{"price":60,"stripe_price":"price_REPLACE_UK_CREDITS_LARGE"}}},"EU":{"plans":{"starter":{"price_monthly":34,"price_annual_monthly":27,"stripe_price_monthly":"price_REPLACE_EU_STARTER_MONTH","stripe_price_annual":"price_REPLACE_EU_STARTER_YEAR"},"professional":{"price_monthly":119,"price_annual_monthly":95,"stripe_price_monthly":"price_REPLACE_EU_PRO_MONTH","stripe_price_annual":"price_REPLACE_EU_PRO_YEAR"},"enterprise":{"price_monthly":299,"price_annual_monthly":239,"stripe_price_monthly":"price_REPLACE_EU_ENT_MONTH","stripe_price_annual":"price_REPLACE_EU_ENT_YEAR"}},"credit_packs":{"small":{"price":6,"stripe_price":"price_REPLACE_EU_CREDITS_SMALL"},"medium":{"price":18,"stripe_price":"price_REPLACE_EU_CREDITS_MEDIUM"},"large":{"price":70,"stripe_price":"price_REPLACE_EU_CREDITS_LARGE"}}},"TR":{"plans":{"starter":{"price_monthly":499,"price_annual_monthly":399},"professional":{"price_monthly":1499,"price_annual_monthly":1199},"enterprise":{"price_monthly":3999,"price_annual_monthly":3199}},"credit_packs":{"small":{"price":200},"medium":{"price":800},"large":{"price":4000}}}}

# Creative Suite / Risk Report
CREATIVE_DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
CREATIVE_DEEPSEEK_BASE_URL=https://api.deepseek.com
CREATIVE_DEEPSEEK_TEXT_MODEL=deepseek-v4-pro
CREATIVE_DEEPSEEK_TIMEOUT=120
CREATIVE_QWEN_API_KEY=YOUR_QWEN_OR_DASHSCOPE_API_KEY
CREATIVE_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
CREATIVE_QWEN_TEXT_MODEL=qwen-max
CREATIVE_QWEN_CLASS_MODEL=qwen-flash
CREATIVE_QWEN_VL_MODEL=qwen3-vl-plus
CREATIVE_QWEN_TIMEOUT=120
CREATIVE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY
CREATIVE_OPENAI_IMAGE_MODEL=gpt-image-2
CREATIVE_OPENAI_IMAGE_SIZE=1024x1024
# quality: low | medium | high. high is ~$0.17/image, medium ~$0.04, low ~$0.01
# First-generation quality (used for initial exploration; many candidates)
CREATIVE_OPENAI_IMAGE_QUALITY=medium
# Revision quality (used when editing a chosen logo; user committed, fidelity matters)
CREATIVE_OPENAI_IMAGE_REVISION_QUALITY=high
CREATIVE_OPENAI_IMAGE_BACKGROUND=auto
CREATIVE_OPENAI_IMAGE_OUTPUT_FORMAT=png
CREATIVE_OPENAI_TIMEOUT=360
# Number of logo candidates per first-generation request. Each multiplies cost linearly.
CREATIVE_LOGO_IMAGES_PER_RUN=4
# Number of logo candidates per revision request (separate so revisions can be a focused single output).
CREATIVE_LOGO_REVISION_IMAGES_PER_RUN=1
CREATIVE_GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
CREATIVE_GEMINI_TEXT_MODEL=gemini-2.5-pro
CREATIVE_GEMINI_CLASS_FALLBACK_MODEL=gemini-2.5-flash-lite
CREATIVE_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ==========================================
# Pipeline Settings
# ==========================================
# Data pipeline: collection → extraction → metadata → ingest
# Linux / Docker:
PIPELINE_BULLETINS_ROOT=/app/bulletins/Marka
# Windows local development:
# PIPELINE_BULLETINS_ROOT=C:\Users\701693\turk_patent\bulletins\Marka
PIPELINE_HEADLESS_BROWSER=true
# Linux / Docker (default):
PIPELINE_SEVEN_ZIP_PATH=/usr/bin/7z
# Windows local development:
# PIPELINE_SEVEN_ZIP_PATH=C:\Program Files\7-Zip\7z.exe
PIPELINE_EMBEDDING_BATCH_SIZE=64
PIPELINE_SKIP_IF_EMBEDDINGS_EXIST=true
PIPELINE_COLLECTION_SCHEDULE_DAY=monday
PIPELINE_COLLECTION_SCHEDULE_HOUR=3
PIPELINE_PIPELINE_SCHEDULE_HOUR=5

# ==========================================
# EUIPO API (EU Trade Mark data collection)
# ==========================================
# Obtain by registering at https://dev.euipo.europa.eu and subscribing to
# the "Trademark search" product. Used by data_collection_eutm.py.
# Default base = sandbox; switch to production with --production CLI flag.
EUIPO_API_KEY=YOUR_EUIPO_API_KEY
EUIPO_API_SECRET=YOUR_EUIPO_API_SECRET
EUIPO_API_BASE=https://api-sandbox.euipo.europa.eu
