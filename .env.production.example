# ============================================
# IP Watch AI - Production Environment
# Copy to .env and fill in your values
# ============================================

# ==========================================
# Application Settings
# ==========================================
APP_NAME="IP Watch AI"
APP_VERSION="1.0.0"
ENVIRONMENT=production
DEBUG=false
USE_UNIFIED_SCORING=true
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==========================================
# Database (PostgreSQL)
# ==========================================
# Docker Compose (services communicate via internal network):
DB_HOST=postgres
DB_PORT=5432
# Local development (connecting to Docker-exposed port):
# DB_HOST=127.0.0.1
# DB_PORT=5433
DB_NAME=trademark_db
DB_USER=turk_patent
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD

# ==========================================
# Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ==========================================
# Authentication (IMPORTANT: Change these!)
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET_KEY=GENERATE_A_SECURE_64_CHAR_SECRET_KEY_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AI Settings
# ==========================================
AI_DEVICE=cuda
USE_FP16=true
USE_TF32=true
CLIP_BATCH_SIZE=64
DINO_BATCH_SIZE=32
TEXT_BATCH_SIZE=256

# ==========================================
# CORS Origins
# ==========================================
# Production:
CORS_ORIGINS=["https://ipwatchai.com","https://www.ipwatchai.com"]
# Development:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==========================================
# File Paths (on host machine)
# ==========================================
DATA_PATH=C:/Users/701693/turk_patent/bulletins
CLIENTS_PATH=C:/Users/701693/turk_patent/clients
HF_HOME=C:/Users/701693/.cache/huggingface
TORCH_HOME=C:/Users/701693/.cache/torch

# ==========================================
# Email (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@ipwatchai.com
FROM_NAME=IP Watch AI

# ==========================================
# Cloudflare Tunnel
# ==========================================
# Tunnel credentials are stored in ./cloudflared/
# TUNNEL_TOKEN is provided when you create the tunnel
CLOUDFLARE_TUNNEL_TOKEN=YOUR_TUNNEL_TOKEN

# ==========================================
# Monitoring (Optional)
# ==========================================
# Sentry DSN for error tracking
SENTRY_DSN=

# ==========================================
# Development Tools (Optional)
# ==========================================
PGADMIN_EMAIL=admin@ipwatchai.com
PGADMIN_PASSWORD=change_this_password

# ==========================================
# Rate Limits
# ==========================================
LOGIN_RATE_LIMIT=5
API_RATE_LIMIT=100

# ==========================================
# iyzico Payment Gateway
# ==========================================
# Production: https://api.iyzipay.com
# Sandbox:    https://sandbox-api.iyzipay.com
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_API_KEY=YOUR_IYZICO_LIVE_API_KEY
IYZICO_SECRET_KEY=YOUR_IYZICO_LIVE_SECRET_KEY
IYZICO_CALLBACK_URL=https://ipwatchai.com/api/v1/payments/callback
IYZICO_WEBHOOK_URL=https://ipwatchai.com/api/v1/payments/webhook

# ==========================================
# Pipeline Settings
# ==========================================
# Data pipeline: collection → extraction → metadata → ingest
# Linux / Docker:
PIPELINE_BULLETINS_ROOT=/app/bulletins/Marka
# Windows local development:
# PIPELINE_BULLETINS_ROOT=C:\Users\701693\turk_patent\bulletins\Marka
PIPELINE_HEADLESS_BROWSER=true
# Linux / Docker (default):
PIPELINE_SEVEN_ZIP_PATH=/usr/bin/7z
# Windows local development:
# PIPELINE_SEVEN_ZIP_PATH=C:\Program Files\7-Zip\7z.exe
PIPELINE_EMBEDDING_BATCH_SIZE=64
PIPELINE_SKIP_IF_EMBEDDINGS_EXIST=true
PIPELINE_COLLECTION_SCHEDULE_DAY=monday
PIPELINE_COLLECTION_SCHEDULE_HOUR=3
PIPELINE_PIPELINE_SCHEDULE_HOUR=5
