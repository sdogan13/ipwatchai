# ============================================
# IP Watch AI - Git Ignore
# ============================================

# Environment & Secrets
.env
.env.*
!.env.example

# Cloudflare credentials (contains tunnel secret)
cloudflared/*.json

# Database dumps
*.dump
*.sql.gz

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/

# Model caches (downloaded at runtime)
*.pt
*.bin
*.onnx
*.safetensors

# Data directories (too large for git)
bulletins/
clients/

# Logs
logs/
*.log

# Uploads & Generated content
uploads/
reports/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store
desktop.ini

# Docker volumes
postgres_data/
redis_data/
pgdata/

# Config backups
config-backup-*/

# Node modules (if any frontend)
node_modules/

# Gemini/Agent artifacts
.gemini/

# Backups
backup_*/

# Temp files
tmp_*
*.tmp

# Windows reserved filenames
nul
NUL

# Embedded Python installation (huge, not needed on server)
python/

# Local PostgreSQL installation (not needed on server)
pgsql/

# Binary executables
*.exe
*.dll

# Chisel tunnel binary
scripts/chisel*
